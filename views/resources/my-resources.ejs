<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-end flex-wrap gap-2 mb-4">
  <div>
    <span class="section-kicker">Your shelf</span>
    <h2 class="mb-0">My Uploads</h2>
  </div>
  <a href="/resources/new" class="btn btn-primary">Upload New</a>
</div>

<% if (resources.length === 0) { %>
  <div class="card doc-sheet text-center py-5">
    <div class="card-body">
      <span class="doc-stamp d-inline-block mb-2">NOTHING FILED YET</span>
      <p class="doc-meta mb-0">You haven't uploaded anything yet.</p>
    </div>
  </div>
<% } else { %>
  <div class="row g-3 reveal-row">
    <% resources.forEach(resource => { %>
      <div class="col-md-4">
        <div class="card h-100 shadow-sm reveal-item">
          <div class="card-body d-flex flex-column">
            <h5 class="card-title"><%= resource.title %></h5>
            <p class="card-text text-muted small mb-3">
              <%= resource.category %> · Semester <%= resource.semester %>
            </p>
            <div class="mt-auto d-flex gap-2">
              <a href="/resources/<%= resource._id %>" class="btn btn-outline-primary btn-sm">View</a>
              <a href="/resources/<%= resource._id %>/edit" class="btn btn-outline-secondary btn-sm">Edit</a>
              <form action="/resources/<%= resource._id %>?_method=DELETE" method="POST" class="d-inline"
                onsubmit="return confirm('Delete &quot;<%= resource.title %>&quot;? This cannot be undone.');">
                <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
              </form>
            </div>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>

<%- include('../partials/footer') %>
