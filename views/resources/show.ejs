<%- include('../partials/header') %>

<div class="row justify-content-center">
  <div class="col-md-9 col-lg-7">
    <div class="card doc-sheet">
      <div class="card-body p-4 p-md-5">
        <div class="call-number mb-2">RESOURCE RECORD</div>
        <h2 class="card-title mb-3"><%= resource.title %></h2>

        <p class="mb-3 d-flex flex-wrap gap-2 align-items-center">
          <span class="badge bg-secondary">sem <%= resource.semester %></span>
          <% if (resource.branch) { %><span class="badge bg-secondary"><%= resource.branch %></span><% } %>
          <% if (resource.year) { %><span class="badge bg-secondary"><%= resource.year %></span><% } %>
          <span class="doc-stamp"><%= resource.category %></span>
        </p>

        <p class="doc-meta mb-1"><strong>Subject:</strong> <%= resource.subject %></p>
        <p class="doc-meta mb-3">
          <strong>Uploaded by:</strong>
          <%= resource.uploadedBy ? resource.uploadedBy.name : 'Unknown' %>
        </p>

        <div class="doc-ruled mb-4"><%= resource.description %></div>

        <div class="d-flex flex-wrap gap-2">
          <a href="/resources/<%= resource._id %>/download" class="btn btn-stamp">
            Download <%= resource.fileName %>
          </a>

          <a href="/resources" class="btn btn-outline-secondary">Back to Resources</a>

          <% if (currentUser && resource.uploadedBy && (currentUser._id.toString() === resource.uploadedBy._id.toString() || currentUser.role === 'admin')) { %>
            <a href="/resources/<%= resource._id %>/edit" class="btn btn-outline-secondary">Edit</a>
            <form action="/resources/<%= resource._id %>?_method=DELETE" method="POST"
              onsubmit="return confirm('Delete &quot;<%= resource.title %>&quot;? This cannot be undone.');">
              <button type="submit" class="btn btn-outline-danger">Delete</button>
            </form>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
