<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-end flex-wrap gap-2 mb-4">
  <div>
    <span class="section-kicker">The catalog</span>
    <h2 class="mb-0">All Resources</h2>
  </div>
  <% if (currentUser) { %>
    <a href="/resources/new" class="btn btn-primary">Upload New</a>
  <% } %>
</div>

<form action="/resources" method="GET" class="row g-2 mb-4" id="filterForm">
  <div class="col-md-4 col-lg-2">
    <input
      type="text"
      name="search"
      class="form-control"
      placeholder="Search by title"
      value="<%= query.search || '' %>"
    />
  </div>
  <div class="col-md-4 col-lg-2">
    <input
      type="text"
      name="subject"
      class="form-control"
      placeholder="Subject"
      value="<%= query.subject || '' %>"
    />
  </div>
  <div class="col-md-4 col-lg-2">
    <select name="branch" class="form-select">
      <option value="">All Branches</option>
      <% ['CSE', 'ECE', 'EE', 'CE', 'CHE', 'MECH', 'BT', 'PIE'].forEach(b => { %>
        <option value="<%= b %>" <%= query.branch === b ? 'selected' : '' %>><%= b %></option>
      <% }) %>
    </select>
  </div>
  <div class="col-md-4 col-lg-2">
    <select name="semester" class="form-select">
      <option value="">All Semesters</option>
      <% for (let i = 1; i <= 8; i++) { %>
        <option value="<%= i %>" <%= String(query.semester) === String(i) ? 'selected' : '' %>>
          Semester <%= i %>
        </option>
      <% } %>
    </select>
  </div>
  <div class="col-md-4 col-lg-2">
    <select name="category" class="form-select">
      <option value="">All Categories</option>
      <% ['Notes', 'PYQs', 'Books', 'Assignments', 'Coding', 'Lab Files', 'Others'].forEach(cat => { %>
        <option value="<%= cat %>" <%= query.category === cat ? 'selected' : '' %>><%= cat %></option>
      <% }) %>
    </select>
  </div>
  <div class="col-md-4 col-lg-2 d-flex gap-2">
    <button type="submit" class="btn btn-primary flex-fill">Filter</button>
    <a href="/resources" class="btn btn-outline-secondary flex-fill">Reset</a>
  </div>
</form>

<% if (resources.length === 0) { %>
  <div class="card doc-sheet text-center py-5">
    <div class="card-body">
      <span class="doc-stamp d-inline-block mb-2">EMPTY SHELF</span>
      <p class="doc-meta mb-0">No resources match your filters. Try widening your search.</p>
    </div>
  </div>
<% } else { %>
  <% const tabColors = { Notes: '#D9A441', PYQs: '#B33A3A', Books: '#4C7A4C', Assignments: '#22314F', Coding: '#7A2E2A', 'Lab Files': '#8B8578', Others: '#D9A441' }; %>
  <div class="row g-3 reveal-row">
    <% resources.forEach(resource => { %>
      <div class="col-md-4 mt-3">
        <div class="card index-card h-100 reveal-item tilt-card" style="--tab-color: <%= tabColors[resource.category] || '#D9A441' %>">
          <span class="corner-tab"><%= resource.category %></span>
          <div class="card-body">
            <div class="call-number mb-1">SEM <%= resource.semester %> · <%= resource.subject %><%= resource.branch ? ' · ' + resource.branch : '' %></div>
            <h5 class="card-title"><%= resource.title %></h5>
            <p class="card-text text-muted small">
              Uploaded by <%= resource.uploadedBy ? resource.uploadedBy.name : 'Unknown' %>
            </p>
            <a href="/resources/<%= resource._id %>" class="btn btn-outline-primary btn-sm">
              View
            </a>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>
<script>
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof gsap !== 'undefined') {
      gsap.registerPlugin(ScrollTrigger);
      document.querySelectorAll('.reveal-row').forEach((row) => {
        gsap.from(row.querySelectorAll('.reveal-item'), {
          scrollTrigger: { trigger: row, start: 'top 88%', once: true },
          y: 26, opacity: 0, duration: 0.55, stagger: 0.06, ease: 'power2.out',
        });
      });
      document.querySelectorAll('.tilt-card').forEach((card) => {
        const rotateX = gsap.quickTo(card, 'rotationX', { duration: 0.4, ease: 'power2.out' });
        const rotateY = gsap.quickTo(card, 'rotationY', { duration: 0.4, ease: 'power2.out' });
        const lift = gsap.quickTo(card, 'y', { duration: 0.4, ease: 'power2.out' });
        card.addEventListener('mousemove', (e) => {
          const rect = card.getBoundingClientRect();
          const px = (e.clientX - rect.left) / rect.width - 0.5;
          const py = (e.clientY - rect.top) / rect.height - 0.5;
          rotateY(px * 10); rotateX(py * -10); lift(-4);
        });
        card.addEventListener('mouseleave', () => { rotateY(0); rotateX(0); lift(0); });
      });
    }
  });

  const filterForm = document.getElementById('filterForm');
  const textInputs = filterForm.querySelectorAll('input[type="text"]');
  const selects = filterForm.querySelectorAll('select');

  let debounceTimer;

  textInputs.forEach((input) => {
    input.addEventListener('input', () => {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => {
        filterForm.submit();
      }, 500);
    });
  });

  selects.forEach((select) => {
    select.addEventListener('change', () => {
      filterForm.submit();
    });
  });
</script>
<% if (totalPages > 1) { %>
  <nav aria-label="Resource pagination" class="mt-4">
    <ul class="pagination justify-content-center">
      <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
        <a class="page-link" href="?<%= new URLSearchParams({ ...query, page: currentPage - 1 }).toString() %>">
          Previous
        </a>
      </li>

      <% for (let i = 1; i <= totalPages; i++) { %>
        <li class="page-item <%= i === currentPage ? 'active' : '' %>">
          <a class="page-link" href="?<%= new URLSearchParams({ ...query, page: i }).toString() %>">
            <%= i %>
          </a>
        </li>
      <% } %>

      <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
        <a class="page-link" href="?<%= new URLSearchParams({ ...query, page: currentPage + 1 }).toString() %>">
          Next
        </a>
      </li>
    </ul>
  </nav>
<% } %>
<%- include('../partials/footer') %>
