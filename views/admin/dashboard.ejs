<%- include('../partials/header') %>

<div class="mb-4">
  <h2 class="mb-1">Admin Dashboard</h2>
  <p class="doc-meta">Manage users and moderate uploaded resources.</p>
</div>

<div class="row g-3 mb-4">
  <div class="col-sm-3">
    <div class="card doc-sheet h-100">
      <div class="card-body text-center py-4">
        <div class="call-number mb-1">TOTAL USERS</div>
        <div class="fs-2 fw-bold" style="font-family: var(--font-mono); color: var(--ink-blue);"><%= stats.userCount %></div>
      </div>
    </div>
  </div>
  <div class="col-sm-3">
    <div class="card doc-sheet h-100">
      <div class="card-body text-center py-4">
        <div class="call-number mb-1">TOTAL RESOURCES</div>
        <div class="fs-2 fw-bold" style="font-family: var(--font-mono); color: var(--ink-blue);"><%= stats.resourceCount %></div>
      </div>
    </div>
  </div>
  <div class="col-sm-3">
    <div class="card doc-sheet h-100">
      <div class="card-body text-center py-4">
        <div class="call-number mb-1">ADMINS</div>
        <div class="fs-2 fw-bold" style="font-family: var(--font-mono); color: var(--ink-blue);"><%= stats.adminCount %></div>
      </div>
    </div>
  </div>
  <div class="col-sm-3">
    <div class="card doc-sheet h-100">
      <div class="card-body text-center py-4">
        <div class="call-number mb-1">BROKEN LINKS</div>
        <div class="fs-2 fw-bold" style="font-family: var(--font-mono); color: <%= stats.brokenCount > 0 ? 'var(--margin-red)' : 'var(--ink-blue)' %>;"><%= stats.brokenCount %></div>
      </div>
    </div>
  </div>
</div>

<div class="card shadow-sm mb-4">
  <div class="card-body p-4">
    <h5 class="card-title mb-3">Users (<%= users.length %>)</h5>
    <div class="table-responsive">
      <table class="table table-hover align-middle" style="font-family: var(--font-mono); font-size: 0.85rem;">
        <thead>
          <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Role</th>
            <th>Joined</th>
            <th class="text-end">Action</th>
          </tr>
        </thead>
        <tbody>
          <% users.forEach(function(user) { %>
            <tr>
              <td><%= user.name %></td>
              <td class="text-truncate" style="max-width: 220px;"><%= user.email %></td>
              <td>
                <% if (user.role === 'admin') { %>
                  <span class="doc-stamp">ADMIN</span>
                <% } else { %>
                  <span class="text-muted">user</span>
                <% } %>
              </td>
              <td><%= user.createdAt.toISOString().slice(0, 10) %></td>
              <td class="text-end">
                <% if (user._id.toString() === currentUser._id.toString()) { %>
                  <span class="text-muted">— you —</span>
                <% } else { %>
                  <form action="/admin/users/<%= user._id %>/role?_method=PUT" method="POST" class="d-inline"
                    onsubmit="return confirm('<%= user.role === 'admin' ? 'Remove admin access for' : 'Grant admin access to' %> <%= user.name %>?');">
                    <button type="submit" class="btn btn-sm <%= user.role === 'admin' ? 'btn-outline-danger' : 'btn-outline-primary' %>">
                      <%= user.role === 'admin' ? 'Demote' : 'Promote' %>
                    </button>
                  </form>
                  <form action="/admin/users/<%= user._id %>?_method=DELETE" method="POST" class="d-inline delete-user-form"
                    data-user-name="<%= user.name %>">
                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                  </form>
                <% } %>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<div class="card shadow-sm mb-4">
  <div class="card-body p-4">
    <h5 class="card-title mb-3">Recent Resources (showing up to 50)</h5>
    <div class="table-responsive">
      <table class="table table-hover align-middle" style="font-family: var(--font-mono); font-size: 0.85rem;">
        <thead>
          <tr>
            <th>Title</th>
            <th>Category</th>
            <th>Sem</th>
            <th>Uploaded By</th>
            <th>Date</th>
            <th>Status</th>
            <th class="text-end">Action</th>
          </tr>
        </thead>
        <tbody>
          <% if (resources.length === 0) { %>
            <tr><td colspan="7" class="text-center text-muted py-3">No resources yet.</td></tr>
          <% } %>
          <% resources.forEach(function(resource) { %>
            <tr>
              <td class="text-truncate" style="max-width: 220px;"><%= resource.title %></td>
              <td><%= resource.category %></td>
              <td><%= resource.semester %></td>
              <td><%= resource.uploadedBy ? resource.uploadedBy.name : 'Unknown' %></td>
              <td><%= resource.createdAt.toISOString().slice(0, 10) %></td>
              <td>
                <% if (resource.broken) { %>
                  <span class="doc-stamp" style="color: var(--margin-red); border-color: var(--margin-red);">BROKEN LINK</span>
                <% } else { %>
                  <span class="text-muted">ok</span>
                <% } %>
              </td>
              <td class="text-end">
                <a href="/resources/<%= resource._id %>" class="btn btn-sm btn-outline-secondary">View</a>
                <form action="/resources/<%= resource._id %>?_method=DELETE" method="POST" class="d-inline"
                  onsubmit="return confirm('Delete &quot;<%= resource.title %>&quot;? This cannot be undone.');">
                  <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                </form>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
  document.querySelectorAll('.delete-user-form').forEach((form) => {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const name = form.dataset.userName;
      const typed = prompt(
        `Delete "${name}"? This also deletes all of their uploaded resources and cannot be undone.\n\nType "confirm" to proceed.`
      );
      if (typed !== null && typed.trim().toLowerCase() === 'confirm') {
        form.submit();
      }
    });
  });
</script>

<%- include('../partials/footer') %>
